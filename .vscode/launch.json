    "version": "0.2.0",
    "configurations": [
        {
            "name": "Debug current file",
            "type": "go",
            "request": "launch",
            "mode": "debug",
            // "port": 2345,
            // "host": "127.0.0.1",
            "program": "${file}",
            "env": {},
            "args": [],
            "showLog": true,
        },
        {
            "name": "Test Current File",
            "type": "go",
            "request": "launch",
            "mode": "test",
            // "port": 2345,
            // "host": "127.0.0.1",
            "program": "${file}",
            "env": {},
            "args": [],
            "showLog": true,
            "console": "internalConsole"
        },
        {
            "name": "Debug CLI",
            "type": "go",
            "request": "launch",
            "mode": "auto",
            "program": "${workspaceFolder}/go/examples/example2/main.go",
            "showLog": false,
            "env": {},
            "args": ["status", "counter1"],
            "logOutput": "dap",
            "console": "integratedTerminal",
        },
        {
            "name": "Test TUI",
            "type": "go",
            "request": "launch",
            "mode": "auto",
            "program": "${file}",
            "env": {},
            "args": [],
            "showLog": false,
            "logOutput": "dap",
            "console": "integratedTerminal",
        },
    ]
}