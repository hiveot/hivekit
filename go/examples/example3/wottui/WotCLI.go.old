package wotcli

import (
	"crypto/x509"
	"fmt"
	"io"
	"log/slog"
	"net/http"
	"time"

	"github.com/araddon/dateparse"
	"github.com/hiveot/hivekit/go/api/td"
	"github.com/hiveot/hivekit/go/modules"
	"github.com/hiveot/hivekit/go/modules/transport/clients"
	clientspkg "github.com/hiveot/hivekit/go/modules/transport/clients/pkg"
	"github.com/hiveot/hivekit/go/modules/factory"
	discoverypkg "github.com/hiveot/hivekit/go/modules/transport/discovery/pkg"
)

const WotCLIModuleType = "wotcli"

// WoTCLI discovers and loads things
type WotCLI struct {
	clientspkg.Consumer

	// The token for authentication
	// todo. right now this is a placeholder
	authToken string

	// The CA for connecting
	// todo right now this is a placeholder
	caCert *x509.Certificate

	// the connection this module links to
	// connection transport.ITransportClient

	// discovery records found after Discover()
	records []*discoverypkg.DiscoveryResult

	// discovered things by thingID
	things map[string]*td.TD
}

func (cli *WotCLI) GetThings() map[string]*td.TD {
	return cli.things
}

// Load the TD from the discovery record URL
// This adds the TD to the known things and returns the TD, or an error
func (cli *WotCLI) LoadDiscoveredTD(r *discoverypkg.DiscoveryResult) (tdoc *td.TD, err error) {

	tdURL := r.AsURL()
	resp, err := http.Get(tdURL)
	if err == nil {
		raw, _ := io.ReadAll(resp.Body)
		tdoc, err = td.UnmarshalTD(string(raw))
	}
	if err == nil {
		cli.things[tdoc.ID] = tdoc
	}
	return tdoc, err
}

// Discover all published things and directories
func (cli *WotCLI) Discover() (err error) {
	// fmt.Print("Discover started ")

	disco := discoverypkg.NewDiscoveryClient()
	// fmt.Println("Discovered Things and Directories on the local network")
	// fmt.Printf("Type       Address    Port   Instance             Schema    TD URL   \n")
	// fmt.Printf("---------- ---------- -----  -------------------  -------   -------  \n")
	waitDuration := time.Second * 1

	cli.records, err = disco.DiscoverThings("", waitDuration, func(r *discoverypkg.DiscoveryResult) bool {

		// tdURL := r.AsURL()

		// load the TD to present nr of affordances
		_, err := cli.LoadDiscoveredTD(r)

		if err != nil {
			fmt.Printf(" Error reading TD: %s\n", err.Error())
		}

		// fmt.Printf("%-10s %-10s %-5d  %-20s %-8s  %s \n",
		// 	r.Type, r.Addr, r.Port, r.Instance, r.Schema, tdURL)

		return false
	})
	// fmt.Printf("Discovery complete. %d records found\n\n", len(cli.records))
	return err
}

func (cli *WotCLI) GetRecords() []*discoverypkg.DiscoveryResult {
	return cli.records
}

// List known things
func (cli *WotCLI) ListThings() {
	fmt.Printf("Thing ID                     Title                         #Props #Events #Actions  Modified (local)  base\n")
	fmt.Printf("---------------------------  ----------------------------  ------ ------- --------  ----------------  -----\n")
	for thingID, tdoc := range cli.things {
		modified := dateparse.MustParse(tdoc.Modified).Local()

		fmt.Printf("%-28s %-28.28s %6d %7d %8d   %-16s  %-20s\n",
			thingID, tdoc.Title, len(tdoc.Properties), len(tdoc.Events), len(tdoc.Actions),
			modified.Format("2006-01-02 15:04"), tdoc.Base)
	}
	fmt.Printf("%d things found\n", len(cli.things))
}

// ReadDirectory reads all the TD in the discovered directory, up to the given limit
// Note that without credentials this can fails
func (cli *WotCLI) ReadDirTDs(dirTD *td.TD, limit int) {
	var n = 0
	slog.Info("ReadDirTDs started")
	slog.Info("ReadDirTDs completed", "count", n)
}

// ReadThing reads the properties of the Thing and display a list of values
// Note that without credentials this can fails
func (cli *WotCLI) ReadThing(thingID string) {
	tdoc, found := cli.things[thingID]
	if !found {
		fmt.Println("No TD for thing: " + thingID)
		return
	}
	fmt.Printf("")
	fmt.Printf("ThingID:     %s\n", tdoc.ID)
	fmt.Printf("Title:       %s\n", tdoc.Title)
	fmt.Printf("Type:        %s\n", tdoc.AtType)
	fmt.Printf("Description: %s\n", tdoc.Description)

	c, err := clients.NewTransportClientFromTD(tdoc, cli.caCert, nil)
	if err == nil {
		defer c.Close()
		c.SetTimeout(time.Minute) // for testing
		err = c.AuthenticateWithToken(cli.GetClientID(), cli.authToken)
	}
	if err == nil {
		cli.SetRequestSink(c.HandleRequest)
	} else {
		slog.Warn("ReadThing: failed", "err", err.Error())
	}

	fmt.Printf("Properties: (%d)\n", len(tdoc.Properties))
	propValues, err := cli.ReadAllProperties(thingID)
	if err != nil {
		fmt.Printf("   ERROR: %s\n", err.Error())
	} else {
		for name := range tdoc.Properties {
			propVal, found := propValues[name]
			if found {
				fmt.Printf("   %s: %v\n", name, propVal)
			} else {
				fmt.Printf("   %s: %s\n", name, propValues[name])
			}
		}
	}

	fmt.Printf("Events: (%d)\n", len(tdoc.Events))
	eventValues, err := cli.ReadAllEvents(thingID)
	if err != nil {
		fmt.Printf("   ERROR: %s\n", err.Error())
	} else {
		// list events defined in the TD with their value
		for name := range tdoc.Events {
			evVal, found := eventValues[name]
			if found {
				fmt.Printf("   %s: %s at %s\n", name, evVal.ToString(0), evVal.Timestamp)
			} else {
				fmt.Printf("   %s: %s\n", name, "n/a")
			}
		}
	}

	fmt.Printf("Actions: (%d)\n", len(tdoc.Actions))
	actionValues, err := cli.QueryAllActions(thingID)
	if err != nil {
		fmt.Printf("   ERROR: %s\n", err.Error())
	} else {
		for name := range tdoc.Actions {
			av, found := actionValues[name]
			if found {
				fmt.Printf("   %s: %s\n", name, av.Status)
			} else {
				fmt.Printf("   %s\n", name)
			}
		}
	}
}

// ShowSummary shows a summary of discovery and things
// intended for display at the top of the commandline input
func (cli *WotCLI) GetSummary() string {
	return fmt.Sprintf("\n%d Things loaded", len(cli.things))
}

func NewWotCLI() *WotCLI {
	cl := &WotCLI{
		records:   make([]*discoverypkg.DiscoveryResult, 0),
		things:    make(map[string]*td.TD),
		Consumer:  *clientspkg.NewConsumer(""),
		authToken: "no-token",
	}
	return cl
}

func NewWotCLIFactory(f factory.IModuleFactory) modules.IHiveModule {
	cl := NewWotCLI()
	return cl
}
